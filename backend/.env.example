# ============================================================
# Prompt Engine Provider Configuration
# ============================================================
# Choose ONE provider: groq | together | huggingface | ollama | gemini | sambanova | cerebras
PROMPT_ENGINE_PROVIDER=groq

# ------------------------------------------------------------
# Groq (Recommended — free, fast, no local install)
# Get your key at: https://console.groq.com
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the default model
# GROQ_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------
# Together AI (Use this if you want Qwen2.5-Coder specifically)
# Get your key at: https://api.together.ai
# ------------------------------------------------------------
TOGETHER_API_KEY=your_together_api_key_here
# Optional: override model (default is Qwen2.5-Coder-7B-Instruct)
# TOGETHER_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# ------------------------------------------------------------
# Hugging Face Inference API (Free but rate-limited)
# Get your key at: https://huggingface.co/settings/tokens
# ------------------------------------------------------------
HUGGINGFACE_API_KEY=your_hf_api_key_here
# Optional: override model (default is Qwen2.5-Coder-1.5B-Instruct)
# HF_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct

# ------------------------------------------------------------
# Google Gemini (Free, fast, generous quotas)
# Get your key at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------
# SambaNova (Ultra-fast, currently free Llama access)
# Get your key at: https://cloud.sambanova.ai/
# ------------------------------------------------------------
SAMBANOVA_API_KEY=your_sambanova_api_key_here
# SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# ------------------------------------------------------------
# Cerebras (Extreme speed, currently free Llama access)
# Get your key at: https://cloud.cerebras.ai/
# ------------------------------------------------------------
CEREBRAS_API_KEY=your_cerebras_api_key_here
# CEREBRAS_MODEL=llama3.1-70b

# ------------------------------------------------------------
# Ollama (Local fallback — no API key needed)
# Requires Ollama running at http://localhost:11434
# ------------------------------------------------------------
# PROMPT_ENGINE_PROVIDER=ollama

# ============================================================
# Supabase Configuration
# ============================================================
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
